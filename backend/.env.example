# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production
APP_DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://vn_accounting:vn_accounting_dev@localhost:5432/vn_accounting
DATABASE_URL_SYNC=postgresql://vn_accounting:vn_accounting_dev@localhost:5432/vn_accounting
SEED_DEMO_DATA=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth / JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# OCR
OCR_ENGINE=paddle
PADDLEOCR_LANG=vi
PADDLEOCR_USE_GPU=false
PADDLEOCR_TIMEOUT_SECONDS=45

# Optional fallback: Google Vision API
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# OR use API key:
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Anthropic Claude Haiku (AI field extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Cloudflare R2 (document storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=vn-accounting-documents
R2_PUBLIC_URL=https://your-r2-bucket.your-account.r2.cloudflarestorage.com

# Vietnam GDT e-Invoice API
GDT_API_BASE_URL=https://hoadondientu.gdt.gov.vn:8443
GDT_API_USERNAME=your-gdt-username
GDT_API_PASSWORD=your-gdt-password
GDT_TAX_CODE=your-company-mst

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=VN Accounting <noreply@your-domain.com>
SMTP_USE_TLS=true
