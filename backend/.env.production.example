# ─── Production Environment Variables ───────────────────────────────────────
# Copy this file to .env when deploying to production.
# NEVER commit .env files to source control.
#
# All sensitive values MUST be loaded from a secrets manager (e.g. Coolify
# secret vars, AWS Secrets Manager, Doppler) rather than hardcoded.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=<generate-and-store-securely>

# Comma-separated list of allowed CORS origins
# Example: https://app.vnaccounting.com,https://admin.vnaccounting.com
ALLOWED_ORIGINS=https://your-domain.com

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vn_accounting
DATABASE_URL_SYNC=postgresql://user:password@host:5432/vn_accounting

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-host:6379/0

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<generate-and-store-securely>

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7           # Shortened for production security
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# ── Celery ─────────────────────────────────────────────────────────────────────
USE_CELERY=false                      # Set to true if running worker service

# ── OCR ────────────────────────────────────────────────────────────────────────
# Options: paddle | google | mock
OCR_ENGINE=paddle
PADDLEOCR_LANG=vi
PADDLEOCR_USE_GPU=false
PADDLEOCR_TIMEOUT_SECONDS=45

# ── Google Vision (optional fallback OCR) ─────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
# OR:
# GOOGLE_VISION_API_KEY=<your-api-key>

# ── AI Extraction ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Cloudflare R2 (document storage) ──────────────────────────────────────────
# Bucket MUST be private (block all public access).
# Access documents ONLY via signed URLs from r2_service.py.
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=vn-accounting-documents
R2_PUBLIC_URL=https://<your-account-id>.r2.cloudflarestorage.com/vn-accounting-documents

# ── Vietnam GDT e-Invoice API ──────────────────────────────────────────────────
GDT_API_BASE_URL=https://hoadondientu.gdt.gov.vn:8443
GDT_API_USERNAME=<your-gdt-username>
GDT_API_PASSWORD=<your-gdt-password>
GDT_TAX_CODE=<your-company-mst>

# ── SMTP Email (transactional — password reset, etc.) ─────────────────────────
# Recommended: use a transactional email service (Resend, Mailgun, AWS SES)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=<your-resend-api-key>
SMTP_FROM=VN Accounting <noreply@your-domain.com>
SMTP_USE_TLS=true

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Leave blank to disable Sentry
SENTRY_DSN=<your-sentry-dsn>
